  },
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "title": "Back to Overview",
      "url": "/d/ciphera-overview",
      "type": "link",
      "icon": "home"
    },
    {
      "title": "Traces Explorer",
      "url": "/d/ciphera-traces",
      "type": "link",
      "icon": "bolt"
    }
  ],
  "liveNow": true,
  "panels": [
    {
      "type": "row",
      "title": "Log Volume (how noisy is each service?)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "collapsed": false
    },
    {
      "title": "Log Volume by Service",
      "description": "Lines per second from each container. Spikes usually mean something interesting is happening.",
      "type": "timeseries",
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 1
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "sum(rate({container=~\"ciphera-validator|ciphera-prover|autoplayer|citrea\"}[1m])) by (container)",
          "legendFormat": "{{container}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 1,
            "fillOpacity": 30,
            "drawStyle": "bars",
            "stacking": {
              "mode": "normal"
            },
            "showPoints": "never"
          },
          "unit": "short"
        },
        "overrides": []
      },
      "datasource": {
        "type": "loki",
        "uid": "loki"
      }
    },
    {
      "type": "row",
      "title": "Real Errors (things that need attention)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "collapsed": false
    },
    {
      "title": "Real Errors (excludes fault injection)",
      "description": "Genuine errors from all services. Fault injections are excluded \u2014 see the panel below.",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{container=~\"ciphera-validator|ciphera-prover|autoplayer\"} |~ \"(?i)error|panic|fatal\" !~ \"FAULT\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Fault Injections (intentional \u2014 autoplayer testing node rejection)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 16
      },
      "collapsed": false
    },
    {
      "title": "Fault Injections (INTENTIONAL)",
      "description": "These are EXPECTED. The autoplayer intentionally submits garbage proofs and double-spends to verify the node rejects them. 'correctly rejected' = good. 'ACCEPTED' = bug.",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 17
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{container=\"autoplayer\"} |~ \"FAULT\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Autoplayer Activity (what transactions are being generated)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "collapsed": false
    },
    {
      "title": "Autoplayer: Normal Rounds (mint, spend, receive, burn)",
      "description": "Regular transaction lifecycle activity.",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 0,
        "y": 26
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{container=\"autoplayer\"} |~ \"round start|round succeeded|round failed|mint successful|spend successful|receive successful|burn\" !~ \"Fault|FAULT\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "title": "Autoplayer: Fault Injection Rounds",
      "description": "Intentional bad behavior \u2014 garbage proofs and double-spend attempts. These SHOULD be rejected by the node.",
      "type": "logs",
      "datasource": {
        "type": "loki",
        "uid": "loki"
      },
      "gridPos": {
        "h": 10,
        "w": 12,
        "x": 12,
        "y": 26
      },
      "targets": [
        {
          "datasource": {
            "type": "loki",
            "uid": "loki"
          },
          "expr": "{container=\"autoplayer\"} |~ \"(?i)fault|garbage|double.spend\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending",
        "dedupStrategy": "none"
      }
    },
    {
      "type": "row",
      "title": "Prover Activity (proof generation & rollup submissions)",
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "collapsed": false
    },
    {
      "title": "Prover: Proof Generation & Rollup",
