{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": true,
  "panels": [
    {
      "title": "Validator Block Height",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [{ "datasource": "Prometheus", "expr": "ciphera_block_height{job=\"ciphera-validator\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }, "overrides": [] }
    },
    {
      "title": "Prover Block Height",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [{ "datasource": "Prometheus", "expr": "ciphera_block_height{job=\"ciphera-prover\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] } }, "overrides": [] }
    },
    {
      "title": "Mempool Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [{ "datasource": "Prometheus", "expr": "ciphera_mempool_size{job=\"ciphera-validator\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 3 }, { "color": "red", "value": 6 }] } }, "overrides": [] }
    },
    {
      "title": "Total Transactions",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [{ "datasource": "Prometheus", "expr": "ciphera_transactions_total{job=\"ciphera-validator\"}", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "mode": "absolute", "steps": [{ "color": "purple", "value": null }] } }, "overrides": [] }
    },
    {
      "title": "Block Height Over Time (Validator vs Prover)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "datasource": "Prometheus", "expr": "ciphera_block_height{job=\"ciphera-validator\"}", "legendFormat": "validator", "refId": "A" },
        { "datasource": "Prometheus", "expr": "ciphera_block_height{job=\"ciphera-prover\"}", "legendFormat": "prover", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10, "showPoints": "auto", "pointSize": 5 } }, "overrides": [] }
    },
    {
      "title": "Transaction Rate (per 30s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [{ "datasource": "Prometheus", "expr": "rate(ciphera_transactions_total{job=\"ciphera-validator\"}[30s]) * 30", "legendFormat": "tx/30s", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 20, "drawStyle": "bars" } }, "overrides": [] }
    },
    {
      "title": "Mempool Over Time",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [{ "datasource": "Prometheus", "expr": "ciphera_mempool_size{job=\"ciphera-validator\"}", "legendFormat": "pending txns", "refId": "A" }],
      "fieldConfig": { "defaults": { "color": { "fixedColor": "orange", "mode": "fixed" }, "custom": { "lineWidth": 2, "fillOpacity": 30 } }, "overrides": [] }
    },
    {
      "title": "Merkle Tree Growth (Validator vs Prover)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "datasource": "Prometheus", "expr": "ciphera_merkle_tree_elements{job=\"ciphera-validator\"}", "legendFormat": "validator", "refId": "A" },
        { "datasource": "Prometheus", "expr": "ciphera_merkle_tree_elements{job=\"ciphera-prover\"}", "legendFormat": "prover", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "lineWidth": 2, "fillOpacity": 10 } }, "overrides": [] }
    }
  ],
  "refresh": "5s",
