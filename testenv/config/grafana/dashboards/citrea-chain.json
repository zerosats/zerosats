      "collapsed": false
    },
    {
      "title": "Rollup Verified Height vs Ciphera Height",
      "description": "The rollup contract on Citrea tracks which Ciphera blocks have been verified with ZK proofs. The gap shows how far behind verification is.",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "ciphera_block_height{job=\"ciphera-validator\"}",
          "legendFormat": "Ciphera produced",
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "citrea_rollup_verified_height",
          "legendFormat": "Rollup verified",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "showPoints": "never"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Ciphera produced"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "green",
                  "mode": "fixed"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Rollup verified"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "fixedColor": "yellow",
                  "mode": "fixed"
                }
              },
              {
                "id": "custom.lineStyle",
                "value": {
                  "fill": "dash",
                  "dash": [
                    10,
                    10
                  ]
                }
              }
            ]
          }
        ]
      }
    },
    {
      "title": "Tokens Locked in Rollup (Bridge Balance)",
      "description": "Total ERC20 tokens deposited into the rollup contract. This is the bridge TVL. Goes up on mints (user deposits from Citrea), goes down on burns (user withdraws to Citrea).",
      "type": "timeseries",
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 7
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "citrea_rollup_tokens_locked",
          "legendFormat": "Bridge TVL (tokens)",
          "refId": "A"
        }
